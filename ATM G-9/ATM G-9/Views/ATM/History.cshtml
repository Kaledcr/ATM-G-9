@model List<Transaccion>

@{
    ViewData["Title"] = "Historial";
}

<div class="atm-container">
    <div class="atm-card">
        <h4> Historial de Transacciones</h4>

        @if (ViewBag.Success == false)
        {
            <div class="alert alert-warning">
                @ViewBag.Message
            </div>
        }
        else
        {
            <table class="table">
                <thead>
                    <tr>
                        <th>Tipo</th>
                        <th>Monto</th>
                        <th>Fecha</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var t in Model)
                    {
                        bool isDeposit = t.Type == Transaccion.transactionType.deposit;

                        string badgeClass = isDeposit ? "badge-deposit" : "badge-withdraw";
                        string icon = isDeposit ? "↑" : "↓";
                        string label = isDeposit ? "Depósito" : "Retiro";

                        <tr>
                            <td>
                                <span class="transaction-badge @badgeClass">
                                    @icon @label
                                </span>
                            </td>
                            <td>₡@t._amount.ToString("N2")</td>
                            <td style="color: var(--text-3); font-size: 0.82rem;">
                                @t.date.ToString("dd/MM/yyyy HH:mm")
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }

        <a href="/ATM/Menu" class="btn btn-primary">
            ← Volver al Menú
        </a>
    </div>
</div>
