@{
    ViewData["Title"] = "Consultar Saldo";
}

<div class="atm-container">
    <div class="atm-card">
        <h4>💰 Saldo Disponible</h4>

        @if (ViewBag.Success == true)
        {
            <div class="alert alert-success balance-display">
                @ViewBag.Message
            </div>
        }
        else
        {
            <div class="alert alert-danger">
                @ViewBag.Message
            </div>
        }

        <a href="/ATM/Menu" class="btn btn-primary">
            ← Volver al Menú
        </a>
    </div>
</div>